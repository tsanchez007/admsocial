{
  "version": 2,
  "crons": [
    {
      "path": "/api/publish",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/generate-image",     "destination": "/api/generate-image" },
    { "source": "/api/notif",              "destination": "/api/notif" },
    { "source": "/login",                  "destination": "/login.html" },
    { "source": "/conectar",               "destination": "/api/conectar" },
    { "source": "/api/conectar",           "destination": "/api/conectar" },
    { "source": "/api/auth/users",         "destination": "/api/auth/users" },
    { "source": "/api/auth/login",         "destination": "/api/auth/login" },
    { "source": "/api/auth/callback",      "destination": "/api/auth/callback" },
    { "source": "/api/accounts",           "destination": "/api/accounts" },
    { "source": "/api/publish-now",        "destination": "/api/publish-now" },
    { "source": "/api/publish",            "destination": "/api/publish" },
    { "source": "/api/posts/:id",          "destination": "/api/posts/[id]" },
    { "source": "/api/posts",              "destination": "/api/posts" },
    { "source": "/script.js",             "destination": "/script.js" },
    { "source": "/style.css",             "destination": "/style.css" },
    { "source": "/(.*)",                  "destination": "/index.html" }
  ]
}
